int countOne(int n){
    int count=0,rem;
    while(n!=0){
        rem=n%2;
        n/=2;
        if(rem==1) count++;
    }
    return count;
}

bool isPrime(int num){
    if(num<=1) return 0;
    if(num==2) return 1;
    for(int i=2;i<=num/2;i++){
        if(num%i==0) return 0;
    }
    return 1;
}

int convertBinary(int num){
    int rem[32],result=0,i=0;
    while(num!=0){
        rem[i]=num%2;
        num/=2;
        i++;
    }
    for(int j=i-1,i=0;j>=0;j--){
      result = (result << 1) | rem[j];
    }
    return result;
}
int countPrimeSetBits(int left, int right) {
    int count=0;
    for(int i=left;i<=right;i++){
        int binary=convertBinary(i);
        int countone=countOne(binary);
        if(isPrime(countone)) count++;
    }
    return count;
    
}
